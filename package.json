{
  "name": "bilpow",
  "version": "4.0.0",
  "description": "Bilan de Puissance - Gestion des bilans de puissance pour tableaux électriques",
  "main": "dist-electron/electron/main.js",
  "author": "BilPow",
  "license": "MIT",
  
  "scripts": {
    "dev": "npm run build:electron && concurrently -n vite,ts,electron -c blue,yellow,green \"vite\" \"npm run watch:electron\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "watch:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:electron && vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
